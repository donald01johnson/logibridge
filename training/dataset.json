{
  "class_names": {
    "0": "Normal",
    "1": "Warning",
    "2": "Critical"
  },
  "feature_names": [
    "temperature_mean_c",
    "temperature_max_c",
    "vibration_mean_g",
    "vibration_max_g",
    "door_open_fraction",
    "door_transition_count"
  ],
  "moving_average_size": 5,
  "random_seed": 42,
  "schema_version": "1.0",
  "split": {
    "test": {
      "Critical": 15,
      "Normal": 18,
      "Warning": 15
    },
    "training": {
      "Critical": 62,
      "Normal": 84,
      "Warning": 62
    },
    "validation": {
      "Critical": 13,
      "Normal": 18,
      "Warning": 13
    }
  },
  "target_windows": {
    "0": 120,
    "1": 90,
    "2": 90
  },
  "total_windows": 300,
  "window_duration_seconds": 30,
  "window_step_seconds": 10
}
